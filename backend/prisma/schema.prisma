model FeatureFlag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  description String?
  isEnabled   Boolean  @default(false) @map("is_enabled")
  rolloutPct  Int      @default(100) @map("rollout_pct") @db.SmallInt
  config      Json     @default("{}")
  updatedBy   String?  @map("updated_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  updater User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("feature_flags")
}

model GlobalSetting {
  key         String   @id @db.VarChar(200)
  value       Json
  description String?
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  updater User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("global_settings")
}

model ErrorLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId   String?  @map("request_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  path        String?
  method      String?  @db.VarChar(10)
  statusCode  Int?     @map("status_code") @db.SmallInt
  errorCode   String?  @map("error_code") @db.VarChar(100)
  message     String?
  stackTrace  String?  @map("stack_trace")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([statusCode])
  @@map("error_logs")
}

model UserFeedback {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?        @map("user_id") @db.Uuid
  type       FeedbackType
  subject    String?        @db.VarChar(300)
  body       String
  metadata   Json           @default("{}")
  status     FeedbackStatus @default(open)
  adminNote  String?        @map("admin_note")
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@map("user_feedback")
}

// =============================================================================
// AI FUTURE CLUSTER
// =============================================================================

model AIConversation {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  title       String?       @db.VarChar(300)
  model       String?       @db.VarChar(100)
  contextType AIContextType @map("context_type")
  isArchived  Boolean       @default(false) @map("is_archived")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId])
  @@map("ai_conversations")
}

model AIMessage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           AIRole
  content        String
  tokensUsed     Int?     @map("tokens_used")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

model AIInsight {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  insightType AIInsightType @map("insight_type")
  title       String?       @db.VarChar(300)
  content     String
  dataSources Json          @default("[]") @map("data_sources")
  periodStart DateTime?     @map("period_start") @db.Date
  periodEnd   DateTime?     @map("period_end") @db.Date
  isRead      Boolean       @default(false) @map("is_read")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_insights")
}
