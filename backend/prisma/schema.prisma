// =============================================================================
// Habito — Personal Operating System
// Prisma Schema — Production Grade
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "views", "relationJoins"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DATABASE_DIRECT_URL")
  extensions = [pgcrypto(schema: "public"), pg_trgm(schema: "public"), unaccent(schema: "public")]
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  active
  disabled
  deleted

  @@map("user_status")
}

enum Theme {
  light
  dark
  system

  @@map("theme")
}

enum RoleName {
  super_admin
  admin
  moderator
  user

  @@map("role_name")
}

enum HabitFrequency {
  daily
  twice_daily
  custom_daily
  weekly
  monthly
  every_x_hours
  quantity
  time_based

  @@map("habit_frequency")
}

enum Priority {
  low
  medium
  high

  @@map("priority")
}

enum HabitLogStatus {
  completed
  skipped
  failed

  @@map("habit_log_status")
}

enum RecoveryPreset {
  no_smoking
  no_alcohol
  no_sugar
  no_social_media
  no_gambling
  no_junk_food
  no_caffeine
  custom

  @@map("recovery_preset")
}

enum RecoveryStatus {
  active
  paused
  completed

  @@map("recovery_status")
}

enum JournalEntryType {
  morning
  evening
  free_write

  @@map("journal_entry_type")
}

enum NoteType {
  general
  gym
  workout_plan
  meal_plan
  meeting
  idea
  book
  shopping
  journal

  @@map("note_type")
}

enum ExerciseCategory {
  strength
  cardio
  flexibility
  hiit
  sports
  other

  @@map("exercise_category")
}

enum Equipment {
  barbell
  dumbbell
  machine
  cable
  bodyweight
  kettlebell
  resistance_band
  pullup_bar
  other
  none

  @@map("equipment")
}

enum SetType {
  normal
  warmup
  dropset
  failure

  @@map("set_type")
}

enum PrType {
  weight
  reps
  volume
  e1rm
  duration
  distance

  @@map("pr_type")
}

enum GoalCategory {
  health
  fitness
  career
  finance
  relationships
  learning
  mental_health
  self_care
  other

  @@map("goal_category")
}

enum GoalType {
  short_term
  medium_term
  long_term

  @@map("goal_type")
}

enum ProgressType {
  percentage
  checklist
  numeric

  @@map("progress_type")
}

enum GoalStatus {
  active
  completed
  abandoned

  @@map("goal_status")
}

enum TimeBlock {
  morning
  afternoon
  evening
  night

  @@map("time_block")
}

enum NotificationType {
  habit_reminder
  recovery_checkin
  streak_at_risk
  goal_deadline
  journal_prompt
  achievement
  weekly_recap
  system
  pr_record

  @@map("notification_type")
}

enum BadgeCategory {
  streak
  milestone
  consistency
  special

  @@map("badge_category")
}

enum XPReason {
  habit_complete
  streak_milestone
  workout_logged
  journal_entry
  note_created
  goal_milestone
  goal_complete
  recovery_day
  badge_earned
  relapse_honesty
  onboarding_complete
  admin_grant

  @@map("xp_reason")
}

enum ActorType {
  user
  admin
  system

  @@map("actor_type")
}

enum ImpersonationReasonCategory {
  bug_investigation
  user_support
  data_verification
  other

  @@map("impersonation_reason_category")
}

enum AttachmentEntityType {
  note
  habit
  journal
  workout
  goal

  @@map("attachment_entity_type")
}

enum AIContextType {
  coach
  journal
  habit
  general

  @@map("ai_context_type")
}

enum AIRole {
  user
  assistant
  system

  @@map("ai_role")
}

enum AIInsightType {
  weekly_summary
  habit_prediction
  recommendation
  pattern

  @@map("ai_insight_type")
}

enum FeedbackType {
  bug
  feature
  complaint
  praise
  other

  @@map("feedback_type")
}

enum FeedbackStatus {
  open
  reviewing
  resolved
  closed

  @@map("feedback_status")
}

enum WorkoutStatus {
  in_progress
  completed
  discarded

  @@map("workout_status")
}

// =============================================================================
// IDENTITY CLUSTER
// =============================================================================

model User {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String     @unique @db.VarChar(255)
  emailVerified   Boolean    @default(false) @map("email_verified")
  username        String     @unique @db.VarChar(50)
  passwordHash    String     @map("password_hash")
  firstName       String     @map("first_name") @db.VarChar(100)
  lastName        String?    @map("last_name") @db.VarChar(100)
  avatarUrl       String?    @map("avatar_url")
  bio             String?
  birthday        DateTime?  @db.Date
  timezone        String     @default("UTC") @db.VarChar(100)
  theme           Theme      @default(system)
  status          UserStatus @default(active)
  onboardingDone  Boolean    @default(false) @map("onboarding_done")
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz(6)
  deletedAt       DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  settings               UserSettings?
  roles                  UserRole[]
  sessions               Session[]
  refreshTokens          RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens    PasswordResetToken[]
  habitCategories        HabitCategory[]
  habits                 Habit[]
  habitLogs              HabitLog[]
  recoveryGoals          RecoveryGoal[]
  relapseLogs            RelapseLog[]
  journalEntries         JournalEntry[]
  noteFolders            NoteFolder[]
  notes                  Note[]
  noteTags               NoteTag[]
  attachments            Attachment[]
  workoutTemplates       WorkoutTemplate[]
  workoutSessions        WorkoutSession[]
  personalRecords        PersonalRecord[]
  bodyMeasurements       BodyMeasurement[]
  progressPhotos         ProgressPhoto[]
  goals                  Goal[]
  plannerTasks           PlannerTask[]
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  userBadges             UserBadge[]
  userLevel              UserLevel?
  xpTransactions         XPTransaction[]
  dailySnapshots         DailySnapshot[]
  lifeBalanceScores      LifeBalanceScore[]
  feedback               UserFeedback[]
  aiConversations        AIConversation[]
  aiInsights             AIInsight[]
  // Admin relations
  auditLogsAsActor       AuditLog[]            @relation("AuditActor")
  impersonationsAsAdmin  ImpersonationSession[] @relation("ImpersonationAdmin")
  impersonationsAsTarget ImpersonationSession[] @relation("ImpersonationTarget")
  assignedRoles          UserRole[]             @relation("RoleAssigner")
  updatedFeatureFlags    FeatureFlag[]
  updatedGlobalSettings  GlobalSetting[]
  // Custom exercises
  exercises              Exercise[]

  @@index([status])
  @@map("users")
}

model UserSettings {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String   @unique @map("user_id") @db.Uuid
  notificationPrefs  Json     @default("{}") @map("notification_prefs")
  privacySettings    Json     @default("{}") @map("privacy_settings")
  dashboardLayout    Json     @default("[]") @map("dashboard_layout")
  plannerConfig      Json     @default("{}") @map("planner_config")
  gymConfig          Json     @default("{}") @map("gym_config")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        RoleName @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy String?  @map("assigned_by") @db.Uuid

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner User? @relation("RoleAssigner", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  userAgent  String?  @map("user_agent")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  deviceName String?  @map("device_name") @db.VarChar(200)
  lastActive DateTime @default(now()) @map("last_active") @db.Timestamptz(6)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId       String    @map("session_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  tokenHash       String    @unique @map("token_hash") @db.VarChar(255)
  family          String    @db.Uuid
  rotationCounter Int       @default(0) @map("rotation_counter")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt          DateTime? @map("used_at") @db.Timestamptz(6)
  revoked         Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([family])
  @@index([userId])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// =============================================================================
// HABIT CLUSTER
// =============================================================================

model HabitCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  color     String?  @db.VarChar(7)
  icon      String?  @db.VarChar(100)
  isGlobal  Boolean  @default(false) @map("is_global")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  habits Habit[]

  @@unique([userId, name])
  @@index([userId])
  @@map("habit_categories")
}

model Habit {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  categoryId      String?        @map("category_id") @db.Uuid
  title           String         @db.VarChar(200)
  description     String?
  icon            String?        @db.VarChar(100)
  color           String?        @db.VarChar(7)
  frequencyType   HabitFrequency @map("frequency_type")
  frequencyConfig Json           @default("{}") @map("frequency_config")
  priority        Priority       @default(medium)
  reminderEnabled Boolean        @default(false) @map("reminder_enabled")
  reminderConfig  Json           @default("{}") @map("reminder_config")
  customFields    Json?          @map("custom_fields")
  startDate       DateTime       @default(now()) @map("start_date") @db.Date
  endDate         DateTime?      @map("end_date") @db.Date
  isArchived      Boolean        @default(false) @map("is_archived")
  archivedAt      DateTime?      @map("archived_at") @db.Timestamptz(6)
  // Denormalized — updated by streak recalculation job
  currentStreak   Int            @default(0) @map("current_streak")
  longestStreak   Int            @default(0) @map("longest_streak")
  totalCompletions Int           @default(0) @map("total_completions")
  successRate     Decimal        @default(0) @map("success_rate") @db.Decimal(5, 2)
  lastCompletedDate DateTime?    @map("last_completed_date") @db.Date
  // search_vector managed via raw SQL trigger
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      HabitCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  logs          HabitLog[]
  goalLinks     GoalHabitLink[]

  @@index([userId, isArchived])
  @@index([categoryId])
  @@index([userId, lastCompletedDate])
  @@map("habits")
}

model HabitLog {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  habitId         String         @map("habit_id") @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  logDate         DateTime       @map("log_date") @db.Date
  status          HabitLogStatus
  value           Decimal?       @db.Decimal(10, 2)
  note            String?
  skipReason      String?        @map("skip_reason") @db.VarChar(200)
  completionCount   Int           @default(1) @map("completion_count") @db.SmallInt
  customFieldValues Json?         @map("custom_field_values")
  loggedAt          DateTime      @default(now()) @map("logged_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, logDate])
  @@index([habitId, logDate])
  @@index([userId, logDate])
  @@index([habitId, status])
  @@map("habit_logs")
}

// =============================================================================
// RECOVERY CLUSTER
// =============================================================================

model RecoveryGoal {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String         @map("user_id") @db.Uuid
  name              String         @db.VarChar(200)
  presetType        RecoveryPreset? @map("preset_type")
  icon              String?        @db.VarChar(100)
  color             String?        @db.VarChar(7)
  personalWhy       String?        @map("personal_why")
  emergencyPlan     String?        @map("emergency_plan")
  startDate         DateTime       @map("start_date") @db.Timestamptz(6)
  status            RecoveryStatus @default(active)
  // Denormalized — updated after each relapse log
  currentStreakDays Int            @default(0) @map("current_streak_days")
  longestStreakDays Int            @default(0) @map("longest_streak_days")
  totalRelapses     Int            @default(0) @map("total_relapses")
  deletedAt         DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  relapseLogs RelapseLog[]

  @@index([userId])
  @@map("recovery_goals")
}

model RelapseLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recoveryGoalId String   @map("recovery_goal_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  relapsedAt     DateTime @default(now()) @map("relapsed_at") @db.Timestamptz(6)
  moodBefore     Int?     @map("mood_before") @db.SmallInt
  triggers       String[] @default([])
  location       String?  @db.VarChar(100)
  notes          String?
  planForNext    String?  @map("plan_for_next")
  streakBroken   Int      @map("streak_broken")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  recoveryGoal RecoveryGoal @relation(fields: [recoveryGoalId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recoveryGoalId, relapsedAt])
  @@index([userId])
  @@map("relapse_logs")
}

// =============================================================================
// JOURNAL CLUSTER
// =============================================================================

model JournalEntry {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  entryDate     DateTime         @map("entry_date") @db.Date
  entryType     JournalEntryType @map("entry_type")
  // Morning-specific fields
  moodMorning   Int?             @map("mood_morning") @db.SmallInt
  energyLevel   Int?             @map("energy_level") @db.SmallInt
  sleepQuality  Int?             @map("sleep_quality") @db.SmallInt
  sleepHours    Decimal?         @map("sleep_hours") @db.Decimal(4, 1)
  gratitude     String[]         @default([])
  intention     String?
  wordOfDay     String?          @map("word_of_day") @db.VarChar(50)
  // Evening-specific fields
  moodEvening   Int?             @map("mood_evening") @db.SmallInt
  dayRating     Int?             @map("day_rating") @db.SmallInt
  wins          String[]         @default([])
  lessons       String?
  wouldDoDiff   String?          @map("would_do_diff")
  tomorrowPrio  String?          @map("tomorrow_prio")
  stressLevel   Int?             @map("stress_level") @db.SmallInt
  // Shared fields
  content       String?
  contentPlain  String?          @map("content_plain")
  tags          String[]         @default([])
  isDraft       Boolean          @default(false) @map("is_draft")
  // search_vector managed via raw SQL trigger
  deletedAt     DateTime?        @map("deleted_at") @db.Timestamptz(6)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entryDate, entryType])
  @@index([userId, entryDate(sort: Desc)])
  @@index([userId, entryType])
  @@index([userId, moodMorning, moodEvening, entryDate])
  @@map("journal_entries")
}

// =============================================================================
// NOTES CLUSTER
// =============================================================================

model NoteFolder {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  parentId  String?   @map("parent_id") @db.Uuid
  name      String    @db.VarChar(200)
  color     String?   @db.VarChar(7)
  icon      String?   @db.VarChar(100)
  sortOrder Int       @default(0) @map("sort_order")
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   NoteFolder? @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children NoteFolder[] @relation("FolderTree")
  notes    Note[]

  @@index([userId])
  @@index([parentId])
  @@map("note_folders")
}

model Note {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  folderId     String?   @map("folder_id") @db.Uuid
  title        String    @default("Untitled") @db.VarChar(500)
  content      String?
  contentPlain String?   @map("content_plain")
  noteType     NoteType  @default(general) @map("note_type")
  isPinned     Boolean   @default(false) @map("is_pinned")
  isFavorite   Boolean   @default(false) @map("is_favorite")
  isArchived   Boolean   @default(false) @map("is_archived")
  archivedAt   DateTime? @map("archived_at") @db.Timestamptz(6)
  wordCount    Int       @default(0) @map("word_count")
  // search_vector managed via raw SQL trigger
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder      NoteFolder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tagMap      NoteTagMap[]
  attachments Attachment[]  @relation("NoteAttachments")

  @@index([userId])
  @@index([folderId])
  @@index([userId, isPinned])
  @@index([userId, noteType])
  @@map("notes")
}

model NoteTag {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  name       String   @db.VarChar(100)
  color      String?  @db.VarChar(7)
  usageCount Int      @default(0) @map("usage_count")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagMap NoteTagMap[]

  @@unique([userId, name])
  @@map("note_tags")
}

model NoteTagMap {
  noteId String @map("note_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

